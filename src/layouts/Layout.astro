---
import Navbar from '../components/Navbar.astro';
import '@fontsource-variable/inter';


const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Enzo Falone — Software Engineer at Google working on Cloud Service Mesh. Full-stack developer with experience in Go, TypeScript, React, and distributed systems." />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href="https://www.enzofalone.com" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <meta property="og:title" content="Enzo Falone — Software Engineer" />
    <meta property="og:description" content="Portfolio of Enzo Falone, Software Engineer at Google working on Cloud Service Mesh." />
    <meta property="og:image" content="https://cdn.jsdelivr.net/gh/enzofalone/enzofalone.com/assets/me.jpg" />
    <meta property="og:url" content="https://www.enzofalone.com" />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <div id="background-gradient"></div>
    <div id="body">
      <slot />
    </div>
    <script data-goatcounter="https://enzofalone.goatcounter.com/count"
            async src="//gc.zgo.at/count.js" is:inline></script>
  </body>
</html>

<style is:global>
  :root {
    --max-width: 800px;
    --navbar-height: 64px;

    --body-color: 17 24 39;
    --theme-background: 10 10 10;

    --landing-text-color: #FCFBF4;
    --text-color: #eeece2;
    --text-inactive-color: hsla(0, 0%, 63%, 1);

    --border: hsla(0, 0%, 100%, 0.14);
    --border-active: hsla(0, 0%, 100%, 0.384);

    --card-bg: #263238;
    --card-bg-dark: #192227;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-smoothing: antialiased;
  }

  body {
    background-color: rgb(var(--body-color));
  }

  body::-webkit-scrollbar {
    width: 4px;
  }

  body::-webkit-scrollbar-track {
    background-color: rgb(var(--theme-background));
  }

  body::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
  }

  #background-gradient {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, hsla(270, 60%, 50%, 0.18), transparent),
      radial-gradient(ellipse 60% 50% at 10% 60%, hsla(260, 50%, 40%, 0.1), transparent),
      radial-gradient(ellipse 50% 40% at 90% 90%, hsla(280, 60%, 45%, 0.1), transparent);
  }

  #body {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
  }

  html {
    font-family: 'Inter Variable', system-ui, sans-serif;
    text-rendering: optimizeLegibility;
    font-optical-sizing: auto;
  }

  section, main {
    scroll-margin-top: var(--navbar-height);
  }
</style>
