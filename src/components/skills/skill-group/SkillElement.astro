---
import { Image } from 'astro:assets';
const { title, image, alt } = Astro.props;
---

<div class="skill-element">
  <Image
    class="skill-image img-crisp"
    width={32}
    height={32}
    src={image}
    alt={alt}
    loading={'lazy'}
    decoding={'async'}
  />
  <span class="skill-title">{title}</span>
</div>

<style>
  .skill-element {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    background-color: var(--card-bg);
    border: 1px solid var(--border);
    border-left: 2px solid hsla(270, 50%, 65%, 0.45);
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    transition: border-color 200ms ease;
  }

  .skill-element:hover {
    border-color: var(--border-active);
    border-left-color: hsla(270, 50%, 65%, 0.8);
  }

  .skill-title {
    color: var(--text-color);
    font-size: 0.875rem;
    font-weight: 500;
  }
</style>

<style is:global>
  .skill-element img {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    max-width: 20px;
    max-height: 20px;
    object-fit: contain;
  }
</style>
