---
import { Image } from 'astro:assets';
const { title, summary, previewPicture, githubUrl } = Astro.props;
---

<div class="project-preview">
  <div class="project-header">
    <h3 class="project-title">{title}</h3>
    <a
      href={githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`${title} GitHub repository`}
      class="github-link"
    >GitHub</a>
  </div>
  <Image
    loading={"lazy"}
    src={previewPicture}
    alt={`${title} preview`}
    width={1200}
    height={720}
  />
  <p class="project-summary">{summary}</p>
</div>

<style>
  .project-preview {
    background-color: var(--card-bg);
    border: 1px solid var(--border);
    border-left: 2px solid hsla(270, 50%, 65%, 0.45);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms ease;
  }

  .project-preview:hover {
    border-color: var(--border-active);
    border-left-color: hsla(270, 50%, 65%, 0.8);
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 1.25rem 0.75rem;
  }

  .project-title {
    color: var(--text-color);
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .github-link {
    color: var(--text-inactive-color);
    font-size: 0.8125rem;
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 2px 10px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .github-link:hover {
    color: var(--text-color);
    border-color: var(--border-active);
  }

  .project-summary {
    color: var(--text-inactive-color);
    font-size: 0.8125rem;
    line-height: 1.6;
    padding: 0.75rem 1.25rem 1rem;
  }
</style>

<style is:global>
  .project-preview img {
    width: 100%;
    height: auto;
    display: block;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
</style>
