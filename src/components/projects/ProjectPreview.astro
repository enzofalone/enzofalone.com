---
import { Image } from 'astro:assets';
const { title, summary, previewPicture, githubUrl } = Astro.props;
---

<div class="project-preview">
  <div class="project-preview-header">
    <h2>{title}</h2>
  <a href={githubUrl} target="_blank" rel="noopener noreferrer" aria-label={`${title} GitHub repository`}><span>Github</span></a>
  </div>
  <Image 
    loading={"lazy"}
    class={'project-preview-img'}
    src={previewPicture}
    alt={'Project image'}
    width={1200}
    height={720}
  />
  <div class="project-preview-body">
    <p>{summary}</p>
  </div>
</div>

<style>
  * {
    color: var(--text-color);
  }
  .project-preview {
    background-color: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem;
    margin-bottom: 2rem;
    transition: border-color 200ms ease;
  }

  .project-preview:hover {
    border-color: var(--border-active);
  }


  .project-preview-body {
    margin-top: 1rem;
    font-size: 16px;
    color: var(--text-color);
  }

  .project-preview-header {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    margin-bottom: 1rem;
    gap: 10px;
  }
  </style>

<style is:global>
  .project-preview img {
    width: 100%;
    height: auto;
    border-radius: 5px;
    display: block;
  }
</style>
