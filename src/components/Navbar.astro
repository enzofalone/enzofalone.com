---
import { Image } from 'astro:assets';
import logo from '../resources/logo.svg';

const logoImageProps = {
  src: logo,
  alt: 'Cube Logo',
};
---

<script>
  const navbar = document.querySelector('#header-container');
  const sentinel = document.querySelector('#dummy-header');
  const toggle = document.querySelector<HTMLButtonElement>('#menu-toggle');
  const mobileMenu = document.querySelector('#mobile-menu');

  const observer = new IntersectionObserver(
    ([entry]) => {
      navbar?.classList.toggle('scroll', !entry.isIntersecting);
    },
    { threshold: 0 }
  );
  if (sentinel) observer.observe(sentinel);

  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    });
  });
</script>

<div id="dummy-header"></div>
<div id="header-container">
  <div id="header">
    <div class="logo-container">
      <a href="/">
        <Image class="logo" {...logoImageProps} />
      </a>
    </div>
    <div id="header-links">
      <a class="link" href="#hero">Home</a>
      <a class="link" href="#skills">Skills</a>
      <a class="link" href="#experiences">Experience</a>
      <a class="link" href="#projects">Projects</a>
      <a id="button-contact" class="link" href="mailto:enzofalone123@gmail.com"
        >Contact Me</a
      >
    </div>
    <button id="menu-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</div>

<div id="mobile-menu" aria-hidden="true">
  <nav>
    <a class="mobile-link" href="#hero">Home</a>
    <a class="mobile-link" href="#skills">Skills</a>
    <a class="mobile-link" href="#experiences">Experience</a>
    <a class="mobile-link" href="#projects">Projects</a>
    <a class="mobile-link mobile-contact" href="mailto:enzofalone123@gmail.com">Contact Me</a>
  </nav>
</div>

<style>
  #dummy-header {
    width: 100%;
    height: var(--navbar-height);
  }

  #header-container {
    width: 100%;
    top: 0;
    position: fixed;
    height: var(--navbar-height);
    z-index: 100;
    transition: background-color 200ms, filter 200ms, border-color 200ms;
  }

  #header {
    display: flex;
    align-items: center;
    height: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .scroll {
    background-color: rgb(25, 23, 41);
    filter: drop-shadow(0px 9px 15px #000);
    border-bottom: 1px solid hsla(0, 0%, 100%, 0.14);
  }

  #header-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin-left: auto;
  }

  #button-contact {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 6px 10px;
    color: var(--text-inactive-color);
    transition: 200ms ease;
  }

  #button-contact:hover {
    border: 1px solid var(--border-active);
    background-color: hsla(0, 0%, 100%, 0.103);
    color: var(--text-color);
  }

  .link {
    color: var(--text-inactive-color);
    font-size: 1rem;
    transition: color 200ms ease;
    text-decoration: none;
  }

  .link:hover {
    color: var(--text-color);
  }

  .logo-container {
    display: flex;
    align-items: center;
  }

  .logo {
    height: 48px;
  }

  /* Hamburger hidden on desktop */
  #menu-toggle {
    display: none;
  }

  /* Mobile menu hidden on desktop */
  #mobile-menu {
    display: none;
  }

  @media (max-width: 640px) {
    #header-links {
      display: none;
    }

    #menu-toggle {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      width: 24px;
      height: 18px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      margin-left: auto;
    }

    #menu-toggle span {
      display: block;
      width: 100%;
      height: 2px;
      background: var(--text-color);
      border-radius: 2px;
      transition: transform 200ms ease, opacity 200ms ease;
      transform-origin: center;
    }

    #menu-toggle[aria-expanded="true"] span:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }

    #menu-toggle[aria-expanded="true"] span:nth-child(2) {
      opacity: 0;
    }

    #menu-toggle[aria-expanded="true"] span:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }

    #mobile-menu {
      display: flex;
      position: fixed;
      inset: 0;
      top: var(--navbar-height);
      z-index: 99;
      background-color: rgb(var(--body-color));
      background-image:
        linear-gradient(to right, hsla(0, 0%, 100%, 0.04) 1px, transparent 1px),
        linear-gradient(to bottom, hsla(0, 0%, 100%, 0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-8px);
      transition: opacity 200ms ease, transform 200ms ease;
    }

    #mobile-menu.open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    #mobile-menu nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
    }

    .mobile-link {
      color: var(--text-inactive-color);
      font-size: 1.5rem;
      text-decoration: none;
      transition: color 200ms ease;
    }

    .mobile-link:hover {
      color: var(--text-color);
    }

    .mobile-contact {
      margin-top: 0.5rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 24px;
      font-size: 1rem;
      transition: border-color 200ms ease, background-color 200ms ease, color 200ms ease;
    }

    .mobile-contact:hover {
      border-color: var(--border-active);
      background-color: hsla(0, 0%, 100%, 0.103);
      color: var(--text-color);
    }
  }
</style>
