---
import { Image } from 'astro:assets';
const { company, companyImgUrl, positions } = Astro.props;
---

<div class="experience-preview">
  <div class="logo-col">
    <Image
      width={150}
      height={150}
      alt={`${company} logo`}
      loading={'lazy'}
      decoding={'async'}
      src={companyImgUrl}
    />
    {positions.length > 1 && <div class="connector" />}
  </div>

  <div class="content-col">
    <span class="company-name">{company}</span>

    {positions.map((pos: any, i: number) => (
      <div class={`position ${i > 0 ? 'position-subsequent' : ''}`}>
        <div class="position-header">
          <span class="job-title">{pos.title}</span>
          <span class="date">{pos.date}</span>
        </div>
        {pos.summary && pos.summary.length > 0 && (
          <ul class="summary-list">
            {pos.summary.map((item: string) => <li>{item}</li>)}
          </ul>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .experience-preview {
    display: flex;
    gap: 1rem;
    background-color: var(--card-bg);
    border: 1px solid var(--border);
    border-left: 2px solid hsla(270, 50%, 65%, 0.45);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    transition: border-color 200ms ease;
  }

  .experience-preview:hover {
    border-color: var(--border-active);
    border-left-color: hsla(270, 50%, 65%, 0.8);
  }

  .logo-col {
    flex-shrink: 0;
    width: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding-top: 2px;
  }

  .connector {
    flex: 1;
    width: 1px;
    background: linear-gradient(to bottom, var(--border), transparent);
    min-height: 1rem;
  }

  .content-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
    flex: 1;
  }

  .company-name {
    color: var(--text-color);
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .position {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .position-subsequent {
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }

  .position-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .job-title {
    color: var(--text-color);
    font-size: 0.875rem;
    font-weight: 500;
    opacity: 0.8;
  }

  .date {
    color: var(--text-inactive-color);
    font-size: 0.8125rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .summary-list {
    padding-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.125rem;
  }

  .summary-list li {
    color: var(--text-inactive-color);
    font-size: 0.8125rem;
    line-height: 1.6;
  }
</style>

<style is:global>
  .logo-col img {
    width: 20px;
    height: 20px;
    max-width: 20px;
    max-height: 20px;
    object-fit: contain;
  }
</style>
